---
interface Props {
  readonly title: string;
  readonly path: string;
  readonly description?: string;
}

const { title, description = title, path } = Astro.props;
const base = 'https://tktb-tess.github.io';
const pageURL = new URL(path, base).href;
const linkCardURL = new URL('/link_card.png', base).href;
---

<meta name='description' content={description} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:type' content='website' />
<meta property='og:url' content={pageURL} />
<meta property='og:site_name' content='tktb-tess.github.io' />
<meta property='og:image' content={linkCardURL} />
<meta name='twitter:card' content='summary' />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={linkCardURL} />
