---
import '../styles/global.css';
import Head from '../components/Head.astro';
import BreadCrumb from '../components/BreadCrumb.astro';
import { pageData, type PageData } from '../modules/data';

interface Props {
  pageData?: PageData;
}

const url = Astro.originPathname;
const { title, description } = Astro.props.pageData ??
  pageData.get(url) ?? { title: '[NO DATA]' };
---

<!doctype html>
<html lang='ja'>
  <Head {url} {title} {description} />
  <body>
    <header>
      <h1 id='title'>
        {title}
      </h1>
    </header>
    <main>
      {url !== '' && <BreadCrumb {url} />}
      <slot />
    </main>
  </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const key = 'gruss';
    if (!localStorage.getItem(key)) {
      const value = 'V2lsbGtvbW1lbiBhdWYgbWVpbmVyIFdlYnNlaXRlIQ==';
      localStorage.setItem(key, value);
    }
  });
</script>

<style lang="postcss">
  @reference '../styles/global.css';
</style>
