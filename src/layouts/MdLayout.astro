---
import '../styles/global.css';
import Preloads from '../components/Preloads.astro';
import OGP from '../components/OGP.astro';
import BreadCrumb from '../components/BreadCrumb.astro';
import type { MarkdownLayoutProps } from 'astro';

type Props = MarkdownLayoutProps<{
  readonly title: string;
  readonly description?: string;
}>;

const { frontmatter, url = '/' } = Astro.props;
const { title, description } = frontmatter;
const isTop = url === '';
---

<!doctype html>
<html lang='ja'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <Preloads />
    <OGP {title} {description} {url} />
    <link rel='icon' href='/favicon.ico' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <h1 id='title'>
        {title}
      </h1>
    </header>
    <main>
      {!isTop && <BreadCrumb {url} />}
      <slot />
    </main>
  </body>
</html>

<style lang="postcss">
  @reference '../styles/global.css';
  @layer components {
    body {
      @apply max-lg:flow-root lg:grid cbg-side ctext-text;
      --min-side: 14rem;
      --max-main: 72rem;
      grid-template-areas:
        'h h h' 
        'l m r';
      grid-template-columns: 
        minmax(min(var(--min-side), 100%), 1fr)
        minmax(0, var(--max-main))
        minmax(min(var(--min-side), 100%), 1fr);
      grid-template-rows: auto 1fr;
    }

    header {
      grid-area: h;
    }

    main {
      @apply flow-root px-4 pb-36 cbg-main min-h-lvh;
      grid-area: m;
    }

    #title {
      @apply text-4xl font-extralight text-balance my-heading text-center;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const key = 'gruss';
    if (!localStorage.getItem(key)) {
      const value = 'V2lsbGtvbW1lbiBhdWYgbWVpbmVyIFdlYnNlaXRlIQ==';
      localStorage.setItem(key, value);
    }
  });
</script>
