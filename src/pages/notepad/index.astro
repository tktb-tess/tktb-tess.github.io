---
import Preloads from '../../components/Preloads.astro';
import OGP from '../../components/OGP.astro';
import BreadCrumb from '../../components/BreadCrumb.astro';
import Notepad from '../../components/Notepad.svelte';
import { pageData } from '../../modules/data';

interface Props {}
const url = Astro.originPathname;
const { title, description } = pageData.get(url) ?? { title: '[NO DATA]' };
---

<!doctype html>
<html lang='ja'>
  <head>
    <meta charset='utf-8' />
    <Preloads />
    <OGP {title} {description} {url} />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='color-scheme' content='light dark' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <h1 id='title'>
        {title}
      </h1>
    </header>
    <main>
      <BreadCrumb {url} />
      <Notepad client:only='svelte' />
    </main>
  </body>
</html>
